# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://curated:curated@localhost:5432/curated_dev

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Session ───────────────────────────────────────────────────
# Must be exactly 64 lowercase hex characters (32 random bytes)
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Firebase Admin ────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Cloudflare R2 ─────────────────────────────────────────────
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=curated-assets
R2_PUBLIC_URL=https://assets.yourdomain.com

# ── Typesense ─────────────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=local-dev-key
TYPESENSE_PROTOCOL=http

# ── OpenAI ────────────────────────────────────────────────────
# Optional — AI suggestion features are disabled when not set
OPENAI_API_KEY=
