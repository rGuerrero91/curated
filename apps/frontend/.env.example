# Firebase project config (public — safe to commit as example values)
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Backend URL — server-side only (no VITE_ prefix = never sent to the browser)
# In production, set this to your deployed API URL (e.g. https://api.curated.app)
BACKEND_URL=http://localhost:3000
