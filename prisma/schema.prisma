generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgcrypto, pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique @map("firebase_uid")
  username    String   @unique @db.Citext
  displayName String?  @map("display_name")
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  websiteUrl  String?  @map("website_url")
  isPrivate   Boolean  @default(false) @map("is_private")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  collections       Collection[]
  links             Link[]
  comments          Comment[]
  likes             Like[]
  followers         Follow[]          @relation("following")
  following         Follow[]          @relation("follower")
  collectionFollows CollectionFollow[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Collections
// ─────────────────────────────────────────────────────────────

model Collection {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  slug        String
  title       String
  description String?
  coverUrl    String?  @map("cover_url")
  isPublic    Boolean  @default(true) @map("is_public")
  aiEnabled   Boolean  @default(false) @map("ai_enabled")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner         User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items         CollectionItem[]
  comments      Comment[]
  likes         Like[]
  tags          CollectionTag[]
  followers     CollectionFollow[]
  aiSuggestions AISuggestion[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([isPublic, createdAt(sort: Desc)])
  @@map("collections")
}

// ─────────────────────────────────────────────────────────────
// Links
// ─────────────────────────────────────────────────────────────

model Link {
  id           String    @id @default(cuid())
  submittedBy  String    @map("submitted_by")
  url          String
  domain       String
  title        String?
  description  String?
  thumbnailUrl String?   @map("thumbnail_url")
  faviconUrl   String?   @map("favicon_url")
  scrapedAt    DateTime? @map("scraped_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  submitter       User             @relation(fields: [submittedBy], references: [id])
  collectionItems CollectionItem[]

  @@index([submittedBy])
  @@index([domain])
  @@map("links")
}

// ─────────────────────────────────────────────────────────────
// Collection Items (link ↔ collection join, ordered)
// ─────────────────────────────────────────────────────────────

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String   @map("collection_id")
  linkId       String   @map("link_id")
  note         String?
  position     Int      @default(0)
  addedAt      DateTime @default(now()) @map("added_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  link       Link       @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@unique([collectionId, linkId])
  @@index([collectionId, position])
  @@map("collection_items")
}

// ─────────────────────────────────────────────────────────────
// Comments (one level of threading via parentId)
// ─────────────────────────────────────────────────────────────

model Comment {
  id           String   @id @default(cuid())
  authorId     String   @map("author_id")
  collectionId String   @map("collection_id")
  parentId     String?  @map("parent_id")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parent     Comment?   @relation("replies", fields: [parentId], references: [id])
  replies    Comment[]  @relation("replies")

  @@index([collectionId, createdAt(sort: Desc)])
  @@map("comments")
}

// ─────────────────────────────────────────────────────────────
// Likes
// ─────────────────────────────────────────────────────────────

model Like {
  userId       String   @map("user_id")
  collectionId String   @map("collection_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([userId, collectionId])
  @@map("likes")
}

// ─────────────────────────────────────────────────────────────
// Follows (user → user)
// ─────────────────────────────────────────────────────────────

model Follow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

// ─────────────────────────────────────────────────────────────
// Collection Follows (user → collection)
// ─────────────────────────────────────────────────────────────

model CollectionFollow {
  userId       String   @map("user_id")
  collectionId String   @map("collection_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([userId, collectionId])
  @@map("collection_follows")
}

// ─────────────────────────────────────────────────────────────
// Tags
// ─────────────────────────────────────────────────────────────

model Tag {
  id   String @id @default(cuid())
  name String @unique @db.Citext

  collections CollectionTag[]

  @@map("tags")
}

model CollectionTag {
  collectionId String @map("collection_id")
  tagId        String @map("tag_id")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([collectionId, tagId])
  @@map("collection_tags")
}

// ─────────────────────────────────────────────────────────────
// AI Suggestions
// ─────────────────────────────────────────────────────────────

model AISuggestion {
  id           String   @id @default(cuid())
  collectionId String   @map("collection_id")
  url          String
  title        String?
  reasoning    String?
  dismissed    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId, dismissed])
  @@map("ai_suggestions")
}
